# Linux power-logger service config
# Install to:
#   /etc/power-logger.env
#
# Ownership/mode:
#   root:power-logger
#   640
SERVICE_USER=power-logger
RING_BUFFER_DAYS=30
INTERVAL_SEC=1
DB_TYPE=sqlite
POWER_SOURCE=apc
# DB_FILE=/var/db/power-logger/power-logger.db
# PGHOST=/tmp
# PGPORT=5432
# PGDATABASE=power_logger_db
# PGUSER=power-logger
# APCACCESS_BIN=apcaccess
# APCACCESS_ARGS=
