#!/bin/sh
# runit service "power-logger": log power draw to SQL (APC or IPMI)
# Supports SQLite file or PostgreSQL via Unix socket
# -------------------------------------------------------------
# Location: /etc/sv/power-logger/run
# Service account: power-logger
#
# Prerequisites (run once as root):
#   pw groupadd -n power-logger || true
#   pw useradd -n power-logger -g power-logger -c "power logger service" -s /usr/sbin/nologin -d /nonexistent -w no || true
#   install -d -o power-logger -g power-logger /var/db/power-logger
#   install -d -o root -g power-logger -m 755 /etc/sv/power-logger/env
#   install -o root -g power-logger -m 640 /dev/null /etc/sv/power-logger/env/.env.power-logger
#   cat > /etc/sv/power-logger/env/.env.power-logger <<'EOF'
#   SERVICE_USER=power-logger
#   RING_BUFFER_DAYS=30
#   INTERVAL_SEC=1
#   DB_TYPE=sqlite
#   EOF
#
# If using PostgreSQL, also set PGHOST, PGPORT, PGDATABASE, PGUSER in the .env file.
# -------------------------------------------------------------
# Enable service: ln -s /etc/sv/power-logger /var/service/
set -eu

SCRIPT_NAME=power-logger
DATE_EPOCH_MODE=""

# Helpers
has_cmd() {
    command -v "$1" >/dev/null 2>&1
}

log() {
    msg="$1"
    if has_cmd logger; then
        logger -t "$SCRIPT_NAME" -p daemon.notice "$msg"
    else
        printf '%s\n' "$msg" >&2
    fi
}

log_warn() {
    msg="$1"
    if has_cmd logger; then
        logger -t "$SCRIPT_NAME" -p daemon.warning "$msg"
    else
        printf '%s\n' "$msg" >&2
    fi
}

log_err() {
    msg="$1"
    if has_cmd logger; then
        logger -t "$SCRIPT_NAME" -p daemon.err "$msg"
    else
        printf '%s\n' "$msg" >&2
    fi
}

log_sql_messages() {
    log_fn="$1"
    operation="$2"
    stderr_file="$3"
    saw_output=false

    while IFS= read -r line || [ -n "$line" ]; do
        saw_output=true
        "$log_fn" "[sql:$operation] $line"
    done <"$stderr_file"

    if [ "$saw_output" != true ]; then
        "$log_fn" "[sql:$operation] command failed"
    fi
}

run_sql_command() {
    sql="$1"
    operation="$2"
    log_fn="$3"
    stderr_file=$(umask 077 && mktemp "/tmp/${SCRIPT_NAME}.sql.XXXXXX") || {
        "$log_fn" "[sql:$operation] failed to create temp file for SQL stderr capture"
        return 1
    }

    if output=$(printf '%s\n' "$sql" | eval "$CLIENT_CMD" 2>"$stderr_file"); then
        rm -f -- "$stderr_file"
        printf '%s' "$output"
        return 0
    fi

    log_sql_messages "$log_fn" "$operation" "$stderr_file"
    rm -f -- "$stderr_file"
    return 1
}

apcaccess_value() {
    eval "$APCACCESS_BIN $APCACCESS_ARGS -u -p $1"
}

# Extract numeric watts from IPMI SDR output.
ipmi_power_meter() {
    eval "$IPMI_CMD" 2>/dev/null | awk -F'|' -v name="$IPMI_SENSOR" '
        $1 ~ name { gsub(/[^0-9.]/, "", $2); if ($2 != "") { print $2; exit } }
    '
}

format_sql_timestamp() {
    tick="$1"
    case "$DATE_EPOCH_MODE" in
    bsd)
        date -u -r "$tick" '+%Y-%m-%d %H:%M:%S+00:00'
        ;;
    gnu)
        date -u -d "@$tick" '+%Y-%m-%d %H:%M:%S+00:00'
        ;;
    *)
        log_err "unsupported DATE_EPOCH_MODE='$DATE_EPOCH_MODE'"
        exit 1
        ;;
    esac
}

detect_date_epoch_mode() {
    probe_tick=0
    if date -u -r "$probe_tick" '+%Y-%m-%d %H:%M:%S' >/dev/null 2>&1; then
        DATE_EPOCH_MODE=bsd
        return 0
    fi
    if date -u -d "@$probe_tick" '+%Y-%m-%d %H:%M:%S' >/dev/null 2>&1; then
        DATE_EPOCH_MODE=gnu
        return 0
    fi
    log_err "unable to determine supported epoch date format"
    exit 1
}

# Environment
ENV_DIR="$(dirname "$0")/env"
# shellcheck disable=SC1091
[ -f "$ENV_DIR/.env.power-logger" ] && . "$ENV_DIR/.env.power-logger"

# Defaults
: "${SERVICE_USER:=power-logger}"
: "${RING_BUFFER_DAYS:=30}"
: "${INTERVAL_SEC:=1}"
: "${DB_TYPE:=sqlite}"
: "${DB_FILE:=/var/db/power-logger/power-logger.db}"
: "${PGHOST:=/tmp}"
: "${PGPORT:=5432}"
: "${PGDATABASE:=power_logger_db}"
: "${PGUSER:=power-logger}"
: "${POWER_SOURCE:=apc}"
: "${APCACCESS_BIN:=apcaccess}"
: "${APCACCESS_ARGS:=}"
: "${IPMI_CMD:=ipmitool sdr}"
: "${IPMI_SENSOR:=Power Meter}"

# Startup validation and privilege drop
if [ "$(id -un)" != "$SERVICE_USER" ]; then
    log "Dropping privileges to '$SERVICE_USER'"
    exec chpst -u "$SERVICE_USER" /bin/sh "$0" "$@"
fi

case "$INTERVAL_SEC" in
'' | *[!0-9]*)
    log_err "INTERVAL_SEC must be a positive integer."
    exit 1
    ;;
0)
    log_err "INTERVAL_SEC must be greater than zero."
    exit 1
    ;;
esac

RING_BUFFER_SIZE=$((RING_BUFFER_DAYS * 86400 / INTERVAL_SEC))
[ "$RING_BUFFER_SIZE" -ge 1 ] || RING_BUFFER_SIZE=1

# SQL setup
INIT_SCHEMA_TMPL=$(
    cat <<'EOS'
-- SQLite or PostgreSQL schema initialization
CREATE TABLE IF NOT EXISTS %TABLE% (
    slot      INTEGER PRIMARY KEY,
    ts        %TSTYPE% NOT NULL DEFAULT CURRENT_TIMESTAMP UNIQUE,
    power_w   REAL    NOT NULL,
    loadpct   REAL    NOT NULL
);
EOS
)

UPSERT_TMPL=$(
    cat <<'EOS'
-- SQLite or PostgreSQL upsert
INSERT INTO %TABLE%(slot, ts, power_w, loadpct) VALUES(
    %CURRENT_SLOT%, '%CURRENT_TS%', %WATTS%, %LOADPCT%
) ON CONFLICT(slot) DO UPDATE SET
    ts       = '%CURRENT_TS%',
    power_w  = EXCLUDED.power_w,
    loadpct  = EXCLUDED.loadpct;
EOS
)

LAST_SLOT_TMPL="SELECT slot FROM %TABLE% ORDER BY ts DESC LIMIT 1;"

# Determine client command and schema substitutions
case "$DB_TYPE" in
sqlite)
    SED_RENDER='s/%TABLE%/watts/g; s/%TSTYPE%/DATETIME/g'
    CLIENT_CMD="sqlite3 '$DB_FILE'"
    ;;
postgres)
    SED_RENDER='s/%TABLE%/power_logger.watts/g; s/%TSTYPE%/TIMESTAMPTZ/g'
    CLIENT_CMD="psql -qAt -h '$PGHOST' -p '$PGPORT' -U '$PGUSER' -d '$PGDATABASE'"
    ;;
*)
    log_err "unsupported DB_TYPE='$DB_TYPE'"
    exit 1
    ;;
esac

# Initialize schema
INIT_SCHEMA_SQL=$(echo "$INIT_SCHEMA_TMPL" | sed "$SED_RENDER")
run_sql_command "$INIT_SCHEMA_SQL" \
    "init-schema" \
    log_err >/dev/null
log "Initialized power logger source='$POWER_SOURCE' db_type='$DB_TYPE' interval='$INTERVAL_SEC' ring_buffer_size='$RING_BUFFER_SIZE'"

# Determine starting slot
LAST_SLOT_SQL=$(echo "$LAST_SLOT_TMPL" | sed "$SED_RENDER")
LAST_SLOT=$(run_sql_command "$LAST_SLOT_SQL" "select-last-slot" log_err)

case "$LAST_SLOT" in
'' | *[!0-9]*) CURRENT_SLOT=0 ;;
*) CURRENT_SLOT=$(((LAST_SLOT + 1) % RING_BUFFER_SIZE)) ;;
esac

# Sampling setup
case "$POWER_SOURCE" in
apc)
    # Fetch NOMPOWER once (constant for the UPS)
    while :; do
        NOMPOWER=$(apcaccess_value NOMPOWER 2>/dev/null || true)
        case "$NOMPOWER" in
        '' | *[!0-9.]*)
            log_warn "invalid NOMPOWER='$NOMPOWER'. Retrying..."
            sleep 5
            ;;
        *)
            log "Using APC nominal power '$NOMPOWER'"
            break
            ;;
        esac
    done
    ;;
ipmi) ;;
*)
    log_err "unsupported POWER_SOURCE='$POWER_SOURCE'"
    exit 1
    ;;
esac

detect_date_epoch_mode
next_tick=$(($(date -u +%s) + INTERVAL_SEC))

while :; do
    # Wait for the next scheduled whole-second sample boundary. If a prior
    # iteration ran long, skip missed intervals instead of catching up inside
    # the same wall-clock second.
    while :; do
        now=$(date -u +%s)
        [ "$now" -ge "$next_tick" ] && break
        sleep 0.1
    done
    sample_tick=$next_tick
    missed_intervals=$(((now - sample_tick) / INTERVAL_SEC))
    next_tick=$((sample_tick + (missed_intervals + 1) * INTERVAL_SEC))
    CURRENT_TS=$(format_sql_timestamp "$sample_tick")

    case "$POWER_SOURCE" in
    apc)
        LOADPCT=$(apcaccess_value LOADPCT 2>/dev/null || true)
        case "$LOADPCT" in
        '' | *[!0-9.]*)
            log_warn "invalid LOADPCT='$LOADPCT'"
            continue
            ;;
        esac
        WATTS=$(echo "$LOADPCT * $NOMPOWER / 100" | bc -l)
        ;;
    ipmi)
        LOADPCT="0"
        WATTS=$(ipmi_power_meter 2>/dev/null || true)
        ;;
    esac

    case "$WATTS" in
    '' | *[!0-9.]*)
        log_warn "invalid watts='$WATTS'"
        continue
        ;;
    esac

    UPSERT_SQL=$(echo "$UPSERT_TMPL" |
        sed "$SED_RENDER; s/%CURRENT_SLOT%/$CURRENT_SLOT/; s/%CURRENT_TS%/$CURRENT_TS/; s/%WATTS%/$WATTS/; s/%LOADPCT%/$LOADPCT/")
    if ! run_sql_command "$UPSERT_SQL" "write-sample" log_err >/dev/null; then
        continue
    fi
    CURRENT_SLOT=$(((CURRENT_SLOT + 1) % RING_BUFFER_SIZE))
done
