#!/bin/sh
set -eu

SCRIPT_NAME=vpn-up
SCRIPT_DIR=$(CDPATH='' cd -- "$(dirname -- "$0")" && pwd)
VPN_RESOLV_CONF=/etc/resolv.conf.vpn
ACTIVE_RESOLV_CONF=/etc/resolv.conf
ENV_CONF=/usr/local/etc/.gateway-env.conf
LOCK_DIR=/var/run
IPFW_SERVICE=ipfw
# Prefer DNS-based detection (UDP) over HTTPS (TCP)
EXTERNAL_IP_METHOD=opendns
OUTBOUND_IP_FAMILY=4
OUTBOUND_RETRY_COUNT=5
OUTBOUND_RETRY_DELAY=5

# Outbound connection settings for curl/dig
CURL_IP_FAMILY="-${OUTBOUND_IP_FAMILY}"
DIG_IP_FAMILY="-${OUTBOUND_IP_FAMILY}"
DIG_TIMEOUT="$OUTBOUND_RETRY_DELAY"
DIG_TRIES="$OUTBOUND_RETRY_COUNT"

# shellcheck disable=SC1091
. "$SCRIPT_DIR/common.sh"

ensure_lock_paths() {
    if [ -L "$LOCK_BASE" ]; then
        log_err "Lock path must not be a symlink: $LOCK_BASE"
        exit 1
    fi
    if [ -e "$LOCK_BASE" ] && [ ! -d "$LOCK_BASE" ]; then
        log_err "Lock path exists but is not a directory: $LOCK_BASE"
        exit 1
    fi
    if [ -L "$LOCK_PID_FILE" ]; then
        log_err "Lock pid file must not be a symlink: $LOCK_PID_FILE"
        exit 1
    fi
    if [ -e "$LOCK_PID_FILE" ] && [ ! -f "$LOCK_PID_FILE" ]; then
        log_err "Lock pid path exists but is not a regular file: $LOCK_PID_FILE"
        exit 1
    fi
}

clear_stale_lock() {
    ensure_lock_paths
    if [ -f "$LOCK_PID_FILE" ] && ! rm -f -- "$LOCK_PID_FILE"; then
        log_err "Failed to remove stale lock pid file: $LOCK_PID_FILE"
        exit 1
    fi
    if [ -d "$LOCK_BASE" ] && ! rmdir "$LOCK_BASE"; then
        log_err "Refusing to remove non-empty stale lock directory: $LOCK_BASE"
        exit 1
    fi
}

release_lock() {
    ensure_lock_paths
    if [ ! -d "$LOCK_BASE" ]; then
        return 0
    fi

    owner_pid=""
    if [ -f "$LOCK_PID_FILE" ]; then
        owner_pid=$(cat "$LOCK_PID_FILE" 2>/dev/null || echo "")
    fi
    if [ "$owner_pid" = "$$" ]; then
        if [ -f "$LOCK_PID_FILE" ] && ! rm -f -- "$LOCK_PID_FILE"; then
            log_err "Failed to remove lock pid file: $LOCK_PID_FILE"
            return 1
        fi
        if ! rmdir "$LOCK_BASE"; then
            log_err "Refusing to remove non-empty lock directory: $LOCK_BASE"
            return 1
        fi
    fi
}

# Ensure the script is run as root.
if [ "$(id -u)" -ne 0 ]; then
    log_err "Error: This script must be run as root. Exiting."
    exit 1
fi

ensure_absolute_path "VPN resolv.conf path" "$VPN_RESOLV_CONF"
ensure_absolute_path "Active resolv.conf path" "$ACTIVE_RESOLV_CONF"
if [ -f "$VPN_RESOLV_CONF" ]; then
    if ! replace_file_atomically "$VPN_RESOLV_CONF" "$ACTIVE_RESOLV_CONF"; then
        log_err "Failed to replace resolv.conf from '$VPN_RESOLV_CONF'"
        exit 1
    fi
    log "Configured resolv.conf for VPN."
fi

# Load environment variables from /usr/local/etc/.gateway-env.conf config file.
ensure_absolute_path "Environment config path" "$ENV_CONF"
# shellcheck disable=SC1090
. "$ENV_CONF"
ensure_absolute_path "OpenVPN template path" "$OVPN_TEMPLATE"

# Configuration: timeouts, intervals, and retry settings.
TUN_IF=$(awk '/dev / {print $2; exit}' <"$OVPN_TEMPLATE")
ensure_safe_interface_name "Tunnel interface" "$TUN_IF"
IP_TIMEOUT=30      # Total seconds to wait for an IP address.
GATEWAY_TIMEOUT=10 # Total seconds to wait for default gateway(s).
INTERVAL=1         # Polling interval in seconds.

# Ensure a single instance with an atomic lock directory.
LOCK_BASE="${LOCK_DIR}/${SCRIPT_NAME}.${TUN_IF}.lock"
LOCK_PID_FILE="${LOCK_BASE}/pid"
while ! mkdir "$LOCK_BASE" 2>/dev/null; do
    ensure_lock_paths

    OLDPID=$(cat "$LOCK_PID_FILE" 2>/dev/null || echo "")
    case "$OLDPID" in
    '' | *[!0-9]*)
        stale_lock=true
        ;;
    *)
        if kill -0 "$OLDPID" 2>/dev/null; then
            log_err "Lock directory exists and process $OLDPID is still running. Exiting."
            exit 0
        fi
        stale_lock=true
        ;;
    esac

    if [ "$stale_lock" = true ]; then
        log "Stale lock directory found. Removing..."
        clear_stale_lock
        continue
    fi
done

ensure_lock_paths
if ! write_file_atomically_mode "$LOCK_PID_FILE" 600 -- printf '%s\n' "$$"; then
    log_err "Failed to write lock pid file: $LOCK_PID_FILE"
    exit 1
fi
trap 'release_lock' EXIT INT TERM HUP

# Restart ipfw if we need to detect and apply rules on a new interface.
if { [ -n "$GIF_IF" ] && ! ipfw list | grep -qwF "$GIF_IF"; } ||
    ! ipfw list | grep -qwF "$TUN_IF"; then
    service "$IPFW_SERVICE" restart
fi

# Set defaults for the Discord notification if not defined.
: "${DISCORD_MENTION:=@everyone}"

json_escape() {
    printf '%s' "$1" | awk 'BEGIN { ORS = "" }
        {
            gsub(/\\/, "\\\\")
            gsub(/"/, "\\\"")
            gsub(/\r/, "")
            if (NR > 1) {
                printf "\\n"
            }
            printf "%s", $0
        }'
}

send_discord() {
    msg="$1"
    payload=$(json_escape "${DISCORD_MENTION} ${msg}")
    log "Sending Discord notification with the following message: $msg"
    curl -s --retry "$OUTBOUND_RETRY_COUNT" --retry-delay "$OUTBOUND_RETRY_DELAY" \
        "$CURL_IP_FAMILY" -X POST -H "Content-Type: application/json" \
        -d "{\"content\": \"${payload}\"}" \
        "$WEBHOOK_URL"
    log "Notification sent successfully."
}

DEFAULT_GW_IPV4_LINE=""
DEFAULT_GW_IPV6_LINE=""

# Poll for default gateways for IPv4 and IPv6 (using netstat).
SECONDS_WAITED=0
DEFAULT_GW_IPV4=""
DEFAULT_IF_IPV4=""
DEFAULT_GW_IPV6=""

while [ "$SECONDS_WAITED" -lt "$GATEWAY_TIMEOUT" ]; do
    # For IPv4, extract the default gateway from netstat.
    DEFAULT_GW_IPV4=$(netstat -rn -f inet 2>/dev/null | awk '$1 == "default" {print $2; exit}')
    DEFAULT_IF_IPV4=$(netstat -rn -f inet 2>/dev/null | awk '$1 == "default" {print $4; exit}')
    # For IPv6, extract the default gateway from netstat (ignoring link-local).
    DEFAULT_GW_IPV6=$(netstat -rn -f inet6 2>/dev/null | awk '$1 == "default" {print $2; exit}')
    if [ -z "$DEFAULT_GW_IPV4" ]; then
        sleep "$INTERVAL"
        SECONDS_WAITED=$((SECONDS_WAITED + INTERVAL))
        continue
    fi
    break
done

if [ -z "$DEFAULT_GW_IPV4" ]; then
    log_err "Error: Failed to discover a default gateway after $GATEWAY_TIMEOUT seconds."
    false
fi

log "Discovered default gateway IPv4='$DEFAULT_GW_IPV4' interface='$DEFAULT_IF_IPV4' IPv6='${DEFAULT_GW_IPV6:-}'"

DISCORD_SUMMARY="\`$(date)\` VPN up on \`${TUN_IF}\`"
[ -n "$DEFAULT_IF_IPV4" ] && DISCORD_SUMMARY="${DISCORD_SUMMARY} via \`${DEFAULT_IF_IPV4}\`"
[ -n "$DEFAULT_GW_IPV4" ] && DEFAULT_GW_IPV4_LINE="gw4: \`${DEFAULT_GW_IPV4}\`"
[ -n "$DEFAULT_GW_IPV6" ] && DEFAULT_GW_IPV6_LINE="gw6: \`${DEFAULT_GW_IPV6}\`"

# Poll for an IPv4 address on the tunnel interface.
SECONDS_WAITED=0
TUN_IPV4=""

while [ "$SECONDS_WAITED" -lt "$IP_TIMEOUT" ]; do
    if ifconfig "$TUN_IF" >/dev/null 2>&1; then
        TUN_IPV4=$(ifconfig "$TUN_IF" | awk '/inet / {print $2; exit}')
    fi
    if [ -z "$TUN_IPV4" ]; then
        sleep "$INTERVAL"
        SECONDS_WAITED=$((SECONDS_WAITED + INTERVAL))
        continue
    fi
    break
done

if [ -z "$TUN_IPV4" ]; then
    log_err "Error: Failed to acquire an IP address on tunnel interface $TUN_IF after $IP_TIMEOUT seconds."
    false
fi

log "Tunnel interface '$TUN_IF' acquired IPv4 '$TUN_IPV4'"

# Define reusable octet for 0–255
OCTET='(25[0-5]|2[0-4][0-9]|1?[0-9]{1,2})'

# Full IPv4 format validation
VALID_IPV4_REGEX="^($OCTET\\.){3}$OCTET\$"

# Reserved/bad subnet ranges with full anchors
BAD_IPV4_REGEX="^(""\
10\\.$OCTET\\.$OCTET\\.$OCTET|""\
127\\.$OCTET\\.$OCTET\\.$OCTET|""\
169\\.254\\.$OCTET\\.$OCTET|""\
172\\.(1[6-9]|2[0-9]|3[0-1])\\.$OCTET\\.$OCTET|""\
192\\.168\\.$OCTET\\.$OCTET|""\
0\\.$OCTET\\.$OCTET\\.$OCTET|""\
100\\.(6[4-9]|[7-9][0-9]|1[01][0-9]|12[0-7])\\.$OCTET\\.$OCTET|""\
255\\.255\\.255\\.255|""\
)\$"

# Normalize dig/curl output to a single IPv4, stripping quotes and trailing junk
normalize_ipv4_output() {
    sed 's/"//g' | awk '
        NF == 1 && $1 ~ /^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+$/ { ip = $1 }
        END { if (ip != "") print ip }
    '
}

# Get external IPv4 address using DNS
case "$EXTERNAL_IP_METHOD" in
opendns)
    EXT_IPV4=$(dig +timeout="$DIG_TIMEOUT" +tries="$DIG_TRIES" +short +search=0 +comments=0 +stats=0 "$DIG_IP_FAMILY" \
        myip.opendns.com @resolver1.opendns.com | normalize_ipv4_output)
    ;;
google)
    EXT_IPV4=$(dig +timeout="$DIG_TIMEOUT" +tries="$DIG_TRIES" +short +search=0 +comments=0 +stats=0 "$DIG_IP_FAMILY" \
        TXT o-o.myaddr.l.google.com @ns1.google.com | normalize_ipv4_output)
    ;;
akamai)
    EXT_IPV4=$(dig +timeout="$DIG_TIMEOUT" +tries="$DIG_TRIES" +short +search=0 +comments=0 +stats=0 "$DIG_IP_FAMILY" \
        whoami.akamai.net @ns1-1.akamaitech.net | normalize_ipv4_output)
    ;;
*)
    EXT_IPV4=""
    ;;
esac

# Fallback to curl only if DNS detection fails
if [ -z "$EXT_IPV4" ]; then
    log "DNS IP detection failed, falling back to HTTPS"
    EXT_IPV4=$(curl -s --retry "$OUTBOUND_RETRY_COUNT" --retry-delay "$OUTBOUND_RETRY_DELAY" \
        "$CURL_IP_FAMILY" https://ifconfig.co | normalize_ipv4_output)
fi

# Check for invalid/missing/bad external IP
if [ -z "$EXT_IPV4" ] ||
    echo "$EXT_IPV4" | grep -qvE "$VALID_IPV4_REGEX" ||
    echo "$EXT_IPV4" | grep -qE "$BAD_IPV4_REGEX"; then
    log_err "Error: External IP is not usable: '$EXT_IPV4'"
    EXT_IPV4=""
else
    log "Validated external IPv4 '$EXT_IPV4'"
fi

GOOD_IPV4_REGEX=$(echo "^(good|nochg) $EXT_IPV4$" | sed 's/\./\\./g')
EXT_IPV4_UPDATE=""

# Bring up IPv6 gateway tunnel if available.
if [ -n "$EXT_IPV4" ] && [ -n "$GIF_IF" ] && [ -n "$INT_IF" ] && [ -n "$GIF_UPDATE_URL" ]; then
    # Update the external IP.
    EXT_IPV4_UPDATE=$(curl -s --retry "$OUTBOUND_RETRY_COUNT" --retry-delay "$OUTBOUND_RETRY_DELAY" \
        "$CURL_IP_FAMILY" -X GET \
        -H "Cache-Control: no-cache, no-store, must-revalidate" \
        "$GIF_UPDATE_URL&myip=$EXT_IPV4")
    log "6in4 update response: '$EXT_IPV4_UPDATE'"
fi

if echo "$EXT_IPV4_UPDATE" | grep -qE "$GOOD_IPV4_REGEX"; then
    # Calculate MTU - 20 bytes for 6in4 overhead.
    GIF_MTU=$(($(ifconfig "$TUN_IF" | awk '/mtu / {print $NF; exit}') - 20))

    # Bring up the 6in4 tunnel.
    ifconfig "$GIF_IF" tunnel "$TUN_IPV4" "$GIF_IPV4_SERVER" mtu "$GIF_MTU"
    ifconfig "$GIF_IF" inet6 "$GIF_IPV6_CLIENT" "$GIF_IPV6_SERVER" prefixlen 128 up
    ifconfig "$INT_IF" inet6 "$GIF_IPV6_LOCAL" prefixlen 64 up

    # Set the default IPv6 route.
    route -n add -inet6 default "$GIF_IPV6_SERVER"

    log "Configured 6in4 gif_if='$GIF_IF' int_if='$INT_IF' mtu='$GIF_MTU' update='$EXT_IPV4_UPDATE'"
else
    if [ -n "$INT_IF" ]; then
        ifconfig "$INT_IF" inet6 "$GIF_IPV6_LOCAL" prefixlen 64 delete || true
    fi

    if [ -n "$EXT_IPV4_UPDATE" ]; then
        log_err "Error: Failed to update external IP: '$EXT_IPV4_UPDATE'"
    else
        log "6in4 not configured; missing usable external IP or tunnel settings"
    fi
fi

DISCORD_MESSAGE="$DISCORD_SUMMARY"
[ -n "$TUN_IPV4" ] && DISCORD_MESSAGE="${DISCORD_MESSAGE}
ip4: \`${TUN_IPV4}\`"
[ -n "$EXT_IPV4" ] && DISCORD_MESSAGE="${DISCORD_MESSAGE}
ext4: \`${EXT_IPV4}\`"
[ -n "$DEFAULT_GW_IPV4_LINE" ] && DISCORD_MESSAGE="${DISCORD_MESSAGE}
${DEFAULT_GW_IPV4_LINE}"
[ -n "$DEFAULT_GW_IPV6_LINE" ] && DISCORD_MESSAGE="${DISCORD_MESSAGE}
${DEFAULT_GW_IPV6_LINE}"
if [ -n "$EXT_IPV4" ] && echo "$EXT_IPV4_UPDATE" | grep -qE "$GOOD_IPV4_REGEX"; then
    DISCORD_MESSAGE="${DISCORD_MESSAGE}
6in4: updated"
else
    DISCORD_MESSAGE="${DISCORD_MESSAGE}
6in4: unavailable"
fi
send_discord "$DISCORD_MESSAGE"
