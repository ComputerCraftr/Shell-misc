#!/bin/sh
set -eu

SCRIPT_NAME=vpn-down
RESOLV_CONF_BACKUP=/etc/resolv.conf.bak
ACTIVE_RESOLV_CONF=/etc/resolv.conf

# Define logging wrapper functions.
log() { logger -t "$SCRIPT_NAME" -p daemon.notice "$*"; }
log_err() { logger -t "$SCRIPT_NAME" -p daemon.err "$*"; }

# Ensure the script is run as root.
if [ "$(id -u)" -ne 0 ]; then
    log_err "Error: This script must be run as root. Exiting."
    exit 1
fi

log "Starting VPN teardown"

if [ -f "$RESOLV_CONF_BACKUP" ]; then
    cp "$RESOLV_CONF_BACKUP" "$ACTIVE_RESOLV_CONF"
    log "Restored resolv.conf to default."
else
    log "No backup resolv.conf found at '$RESOLV_CONF_BACKUP'; leaving resolv.conf unchanged."
fi
